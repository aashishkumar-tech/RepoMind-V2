# ──────────────────────────────────────────────────────
# RepoMind — .gitignore
# ──────────────────────────────────────────────────────

# ───── Python ─────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ───── Virtual Environments ─────
venv/
venv*/
env/
ENV/
env.bak/
venv.bak/
.venv/
.venv*/
virtualenv/

# ───── Environment Variables / Secrets ─────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.pem
*.key
*.crt
secrets/
.secrets/
credentials.json
service-account*.json

# Never commit GitHub App private keys
github-app*.pem
*-private-key.pem

# ───── AWS ─────
.aws/
samconfig.toml
.aws-sam/
cdk.out/
.cdk.staging/

# Lambda packaging artifacts
dist/
*.zip
lambda-layer/
deployment-package/
package/

# ───── Testing ─────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
.cache/
test-results/
junit*.xml

# ───── Type Checking / Linting ─────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
.pyright/

# ───── IDE / Editors ─────
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ───── Jupyter ─────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ───── OS Generated ─────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ───── Logs & Debug ─────
*.log
logs/
log/
debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ───── RepoMind Specific ─────
# Local artifacts from test runs
artifacts/
events/
local-storage/
sample-events/output/

# Cached LLM responses (for local dev)
.llm_cache/
.cache_llm/

# Local Qdrant / vector store
qdrant_storage/
vectors/

# Test fixtures with real data
fixtures/real-*/
fixtures/private/

# Generated docs
docs/_build/
site/

# Profiling output
*.prof
*.pstats
.prof/

# ───── Misc ─────
*.bak
*.tmp
*.temp
*.old
*.orig
.scratch/
scratch/
playground/
NOTES.md
TODO.md

# ───── Deployment Artifacts (NEVER COMMIT) ─────
current_env.json
env-update.json
env-backup*.json
backup-env-*.json
staged-preview.txt