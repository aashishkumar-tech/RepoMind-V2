# ──────────────────────────────────────────────
# RepoMind V2 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ──────────────────────────────────────────────

# ── App ──
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── GitHub App ──
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=private-key.pem
GITHUB_WEBHOOK_SECRET=

# V2 (production / Lambda) — fetch the GitHub App private key from Secrets Manager
# instead of a local PEM file. Leave blank if using GITHUB_PRIVATE_KEY_PATH above.
GITHUB_PRIVATE_KEY_SECRET_ARN=

# ── Target repo for local testing ──
TARGET_REPO=

# ── Groq LLM (local-dev fallback) ──
GROQ_API_KEY=

# ── Azure OpenAI (required for hackathon submission) ──
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ── Azure Storage (optional — used alongside S3) ──
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=repomind-events

# ── Azure Service Bus (optional — used alongside SQS) ──
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
AZURE_SERVICE_BUS_QUEUE=repomind-events

# ── OpenAI Embeddings ──
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# 📧 Email Notifications (V2 — Premium HTML Templates)
# ──────────────────────────────────────────────
# Six lifecycle events trigger styled HTML emails:
#   🔴 ci_failed         🟡 pr_review_needed   ✅ pr_merged
#   ❌ pr_rejected       🔁 rollback           ⚠️ pipeline_error
# Per-repo overrides supported via `.repomind.yml > notifications:` block.

# Master switch — set to false to silence ALL emails (dev/staging)
NOTIFICATIONS_ENABLED=true

# SMTP server config (Gmail example shown — works with any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=alerts@yourcompany.com
SMTP_FROM=alerts@yourcompany.com
SMTP_FROM_NAME=RepoMind

# Default recipients (comma-separated). Repos can override via .repomind.yml.
NOTIFICATION_EMAILS=team@yourcompany.com,oncall@yourcompany.com

# Password source — choose ONE:
#
# Option A (RECOMMENDED for AWS Lambda / production):
#   Store the SMTP password in AWS Secrets Manager as a JSON blob:
#       { "password": "your-gmail-app-password" }
#   Then reference it here. The notifier fetches + caches it per warm container.
SMTP_PASSWORD_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:YOUR_ACCOUNT_ID:secret:repomind/smtp-password-XXXXXX
#
# Option B (LOCAL DEV ONLY — never commit!):
#   Plaintext password directly in env var. Used as fallback if
#   SMTP_PASSWORD_SECRET_ARN is empty or AWS Secrets Manager is unreachable.
# SMTP_PASSWORD=your-gmail-app-password

# ── Legacy email vars (V1 — kept for backward compatibility) ──
# ⚠️  DEPRECATED: The new notifier uses SMTP_* vars above. These remain only
#     so older scripts don't break. New deployments should ignore them.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── Qdrant Vector DB ──
QDRANT_HOST=localhost
QDRANT_PORT=6333

# V2 (production) — managed Qdrant cloud endpoint
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=repomind-events

# ── AWS ──
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
S3_SAM_BUCKET=repomind-sam-deployments
S3_DATA_BUCKET=repomind-data

# V2 — SQS queue URL for the worker Lambda trigger
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/YOUR_ACCOUNT_ID/repomind-queue

# ── Observability ──
METRICS_ENABLED=false
PUSHGATEWAY_URL=
KILL_SWITCH_PARAM=/repomind/kill_switch

# ── Verifier / Rollback ──
VERIFICATION_ENABLED=true
MAX_ROLLBACKS_PER_HOUR=3